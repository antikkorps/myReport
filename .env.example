# Copy to .env and fill in real values. Never commit .env.
NODE_ENV=development

# Postgres
DATABASE_URL=postgres://myreport:myreport@localhost:5432/myreport

# Redis
REDIS_URL=redis://localhost:6379

# S3-compatible storage (MinIO in dev)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=myreport

# Auth
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Encryption key for BYOK API keys (libsodium, 32 bytes base64)
BYOK_MASTER_KEY=

# AI providers (optional — only set for managed mode)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
