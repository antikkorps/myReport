# Copy to .env and fill in real values. Never commit .env.
#
# The root .env file is read both by the apps (via dotenv/node --env-file)
# and by docker compose (`pnpm dev:up`). Keep it in sync.

NODE_ENV=development

# --- Local infra (docker compose) ---
# Override these if the defaults clash with something already running on your host.
COMPOSE_PROJECT_NAME=myreport

# Postgres
POSTGRES_USER=myreport
POSTGRES_PASSWORD=myreport
POSTGRES_DB=myreport
POSTGRES_HOST_PORT=5433

# Redis
REDIS_HOST_PORT=6379

# MinIO (S3-compatible)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
S3_BUCKET=myreport

# --- App connection strings (derived from the above) ---
DATABASE_URL=postgres://myreport:myreport@localhost:5433/myreport
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# --- Auth ---
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Encryption key for BYOK API keys (libsodium, 32 bytes base64)
BYOK_MASTER_KEY=

# --- AI providers (optional, managed mode only) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
